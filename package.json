{
  "name": "cowork-agent-for-kintone",
  "private": true,
  "version": "0.0.0",
  "description": "Cowork Agent for kintone — Claude Managed Agents 連携 kintone プラグイン (monorepo root)",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "plugin:build": "pnpm --filter @cowork-agent/plugin run build",
    "plugin:keygen": "pnpm --filter @cowork-agent/plugin run keygen",
    "plugin:pack": "pnpm --filter @cowork-agent/plugin run pack",
    "plugin:upload": "pnpm --filter @cowork-agent/plugin run upload",
    "plugin:deploy": "pnpm --filter @cowork-agent/plugin run deploy",
    "plugin:app-deploy": "pnpm --filter @cowork-agent/plugin run app-deploy",
    "plugin:release": "pnpm --filter @cowork-agent/plugin run release",
    "plugin:release:minor": "pnpm --filter @cowork-agent/plugin run release:minor",
    "plugin:release:major": "pnpm --filter @cowork-agent/plugin run release:major",
    "plugin:e2e": "pnpm --filter @cowork-agent/plugin run e2e",
    "plugin:e2e:ui": "pnpm --filter @cowork-agent/plugin run e2e:ui",
    "plugin:e2e:install": "pnpm --filter @cowork-agent/plugin run e2e:install",
    "worker:deploy": "node --env-file=.env packages/plugin/scripts/deploy-worker.mjs",
    "verify:customize": "node --env-file=.env scripts/verify-customize-rest-api.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  }
}

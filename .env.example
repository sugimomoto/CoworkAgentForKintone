# =====================================================================
# Cowork Agent for kintone — ローカル開発用環境変数のテンプレート
# =====================================================================
# 1. このファイルを `.env` にコピー: `cp .env.example .env`
# 2. 値を埋める
# 3. `.env` は .gitignore で除外済み (絶対にコミットしないこと)
# =====================================================================

# --- kintone (プラグインアップロード先) -------------------------------
# 自分の kintone 開発環境を指定 (システム管理者権限を持つアカウント)
KINTONE_BASE_URL=https://example.cybozu.com
KINTONE_USERNAME=your-login-name
KINTONE_PASSWORD=your-password

# --- Anthropic (E2E / 検証スクリプト用) --------------------------------
# 設定済の場合のみ config.spec の deploy テストや scripts/verify-mcp-oauth.mjs が実行される。
# 本番 plugin の API Key は kintone admin が ConfigScreen で手動入力する (これとは別)。
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- E2E テスト (任意) -------------------------------------------------
# プラグインが追加されたテスト用アプリの ID
# KINTONE_TEST_APP_ID=42
# 設定画面 E2E に必要なプラグイン ID (アップロード時に表示される 32 文字の英数字)
# KINTONE_TEST_PLUGIN_ID=gmiemhlibenekaafbkjhnpdjipamphkh

# --- Cloudflare (kintone-mcp Worker デプロイ用) -----------------------
# Cloudflare API Token と Account ID。
# Token は https://dash.cloudflare.com/profile/api-tokens で
# "Edit Cloudflare Workers" テンプレートで発行。
# Account ID はダッシュボード右側に表示されている 16 進文字列。
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# --- kintone OAuth クライアント (検証スクリプト scripts/verify-mcp-oauth.mjs 用) ---
# 本番 plugin では admin が ConfigScreen で入力するため不要。検証スクリプトのみ参照。
# kintone 共通管理 → 外部連携 → OAuth クライアントで作成し、redirect_uri は
# Worker の /oauth/callback を指定する (例: https://<worker>/oauth/callback)。
# KINTONE_OAUTH_CLIENT_ID=
# KINTONE_OAUTH_CLIENT_SECRET=
# KINTONE_OAUTH_AUTHORIZATION_URL=https://example.cybozu.com/oauth2/authorization
# KINTONE_OAUTH_TOKEN_URL=https://example.cybozu.com/oauth2/token
# KINTONE_OAUTH_SCOPE=k:app_record:read k:app_record:write k:app_settings:read k:file:read

# Phase 1b-2 (旧 JWT 方式) の secrets は Phase 1b-3 で廃止されました。
# Worker は KINTONE_SUBDOMAIN 1 つだけ ([vars]) で動作し、Worker secret は不要です。

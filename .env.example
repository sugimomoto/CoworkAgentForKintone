# =====================================================================
# Cowork Agent for kintone — ローカル開発用環境変数のテンプレート
# =====================================================================
# 1. このファイルを `.env` にコピー: `cp .env.example .env`
# 2. 値を埋める
# 3. `.env` は .gitignore で除外済み (絶対にコミットしないこと)
# =====================================================================

# --- kintone (プラグインアップロード先) -------------------------------
# 自分の kintone 開発環境を指定 (システム管理者権限を持つアカウント)
KINTONE_BASE_URL=https://example.cybozu.com
KINTONE_USERNAME=your-login-name
KINTONE_PASSWORD=your-password

# --- Anthropic (E2E テスト用) -----------------------------------------
# 設定済の場合のみ config.spec の deploy テストが実行される。
# 未設定なら deploy テストは skip されるが、smoke / live spec は引き続き実行される。
# ※ live spec は kintone admin で手動入力済の API Key で動作するため別途設定不要。
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- E2E テスト (任意) -------------------------------------------------
# プラグインが追加されたテスト用アプリの ID
# KINTONE_TEST_APP_ID=42
# 設定画面 E2E に必要なプラグイン ID (アップロード時に表示される 32 文字の英数字)
# KINTONE_TEST_PLUGIN_ID=gmiemhlibenekaafbkjhnpdjipamphkh

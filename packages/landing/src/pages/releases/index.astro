---
import HelpLayout from '../../layouts/HelpLayout.astro';
import { releases, type ReleaseIcon } from '../../data/releases';

const REPO = 'https://github.com/sugimomoto/CoworkAgentForKintone';

const slug = (v: string) =>
  v
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');

const fmtDate = (d: string) => {
  const [y, m, day] = d.split('-');
  return `${y}年${Number(m)}月${Number(day)}日`;
};

const toc = releases.map((r) => ({ href: `#${slug(r.version)}`, label: r.version }));

// lucide 風のインライン SVG アイコン（stroke=currentColor）。
const ICON_PATHS: Record<ReleaseIcon, string> = {
  bell: '<path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  grid: '<rect x="3" y="3" width="7" height="7" rx="1.4"/><rect x="14" y="3" width="7" height="7" rx="1.4"/><rect x="3" y="14" width="7" height="7" rx="1.4"/><rect x="14" y="14" width="7" height="7" rx="1.4"/>',
  shield: '<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  wrench:
    '<path d="M14.7 6.3a4 4 0 0 0-5.2 5L4 16.8 7.2 20l5.5-5.5a4 4 0 0 0 5-5.2l-2.6 2.6-2.1-.5-.5-2.1z"/>',
  doc: '<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 17h6"/>',
};
const iconSvg = (name: ReleaseIcon) =>
  `<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${ICON_PATHS[name]}</svg>`;
---

<HelpLayout
  title="リリースノート — Cowork Agent for kintone"
  description="Cowork Agent for kintone の更新情報。各リリースの新機能・改善・修正の要点をまとめています。"
  canonical="/releases/"
  crumb="リリースノート"
  tocLabel="リリース"
  toc={toc}
>
  <span class="eyebrow">CHANGELOG · 更新情報</span>
  <h1 id="top">リリースノート</h1>
  <p class="lead">
    Cowork Agent for kintone の各リリースの要点をまとめています。すべてのコミット履歴は
    <a href={`${REPO}/releases`} target="_blank" rel="noopener">GitHub Releases</a> を参照してください。
  </p>

  {
    releases.map((r) => (
      <section class="rel" id={slug(r.version)}>
        <div class="rel-head">
          <span class="rel-ver mono">{r.version}</span>
          <span class="rel-date">{fmtDate(r.date)}</span>
          <a class="rel-link" href={`${REPO}/releases/tag/${r.tag}`} target="_blank" rel="noopener">
            GitHub で見る →
          </a>
        </div>
        <h2 class="rel-title">{r.title}</h2>
        <p class="rel-summary">{r.summary}</p>
        <ul class="rel-feats">
          {r.highlights.map((h) => (
            <li class="rel-feat">
              <span class="rel-ico" set:html={iconSvg(h.icon)} />
              <div class="rel-tx">
                <div class="rel-ft">
                  {h.title}
                  {h.isNew && <span class="rel-new">NEW</span>}
                </div>
                <div class="rel-fd">{h.desc}</div>
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</HelpLayout>

<style>
  .rel {
    margin: 0 0 8px;
    padding: 34px 0 38px;
    border-bottom: 1px solid var(--border);
  }
  .rel:last-of-type {
    border-bottom: none;
  }
  .rel-head {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .rel-ver {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #3a2f24;
    background: #ffbf00;
    padding: 5px 11px;
    border-radius: var(--r-sm);
    box-shadow: 0 3px 10px rgba(255, 191, 0, 0.3);
  }
  .rel-date {
    font-size: 13px;
    color: var(--subtle);
  }
  .rel-link {
    margin-left: auto;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--accent-deep);
    text-decoration: none;
    white-space: nowrap;
  }
  .rel-link:hover {
    text-decoration: underline;
  }
  .rel-title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin: 0 0 8px;
    scroll-margin-top: 84px;
  }
  .rel-summary {
    font-size: 14.5px;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 18px;
    max-width: 680px;
  }
  .rel-feats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .rel-feat {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 15px 17px;
    box-shadow: 0 1px 3px rgba(35, 18, 0, 0.04);
  }
  .rel-ico {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: 11px;
    background: var(--accent-soft);
    color: var(--accent-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .rel-tx {
    min-width: 0;
  }
  .rel-ft {
    font-size: 15.5px;
    font-weight: 700;
    line-height: 1.35;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .rel-new {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #3a2f24;
    background: #ffbf00;
    padding: 2px 8px;
    border-radius: 999px;
  }
  .rel-fd {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.6;
    margin-top: 3px;
  }
</style>

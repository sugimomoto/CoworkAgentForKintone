---
// Icon — stroke-1.7~1.8 currentColor SVGs, ported from ui-kit.jsx I.* glyphs.
type IconName =
  | 'search'
  | 'check'
  | 'arrow'
  | 'send'
  | 'shield'
  | 'panel'
  | 'async'
  | 'clock'
  | 'bolt'
  | 'doc'
  | 'swap'
  | 'github'
  | 'download'
  | 'lock'
  | 'scale'
  | 'spark'
  | 'star'
  | 'star-avatar'
  | 'qchat';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 16, class: className } = Astro.props;
---

{name === 'search' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><circle cx="7" cy="7" r="4.5"></circle><path d="m13.5 13.5-3-3"></path></svg>
)}
{name === 'check' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="m3.5 8.5 3 3 6-7"></path></svg>
)}
{name === 'arrow' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M3 8h9M8 4l4 4-4 4"></path></svg>
)}
{name === 'send' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M14 2 7 9M14 2l-4.5 12-2.5-5-5-2.5L14 2z"></path></svg>
)}
{name === 'shield' && (
  <svg width={size} height={size} viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M10 2 3.5 4.5v5C3.5 14 6.5 16.5 10 17.5c3.5-1 6.5-3.5 6.5-8v-5L10 2z"></path><path d="m7.2 9.8 2 2 3.6-4.2"></path></svg>
)}
{name === 'panel' && (
  <svg width={size} height={size} viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><rect x="2.5" y="3.5" width="15" height="13" rx="2.5"></rect><path d="M12.5 3.5v13"></path><path d="M14.5 7.5h1M14.5 10h1"></path></svg>
)}
{name === 'async' && (
  <svg width={size} height={size} viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M16.5 6.5A7 7 0 1 0 17 10"></path><path d="M16.5 3v3.5H13"></path><path d="M10 6.5V10l2.3 2.3"></path></svg>
)}
{name === 'clock' && (
  <svg width={size} height={size} viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><circle cx="7" cy="7" r="5.2"></circle><path d="M7 4.3V7l1.8 1.1"></path></svg>
)}
{name === 'bolt' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M9 1.5 3.5 9H7l-.5 5.5L12.5 7H9z"></path></svg>
)}
{name === 'doc' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M3.5 2h5l4 4v8h-9z"></path><path d="M8.5 2v4h4"></path><path d="M5.5 9h5M5.5 11.5h3"></path></svg>
)}
{name === 'swap' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M3 5h8M9 3l2 2-2 2"></path><path d="M13 11H5m2-2-2 2 2 2"></path></svg>
)}
{name === 'github' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="currentColor" class={className} aria-hidden="true"><path d="M8 .2a8 8 0 0 0-2.5 15.6c.4.07.55-.17.55-.38v-1.3c-2.2.48-2.67-1.07-2.67-1.07-.36-.92-.88-1.16-.88-1.16-.72-.5.05-.48.05-.48.8.05 1.22.82 1.22.82.71 1.2 1.86.86 2.32.66.07-.52.28-.86.5-1.06-1.76-.2-3.6-.88-3.6-3.9 0-.86.3-1.57.82-2.12-.08-.2-.36-1 .08-2.1 0 0 .67-.21 2.2.81a7.6 7.6 0 0 1 4 0c1.53-1.02 2.2-.8 2.2-.8.44 1.1.16 1.89.08 2.09.5.55.82 1.26.82 2.12 0 3.03-1.85 3.7-3.61 3.89.28.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 .2z"></path></svg>
)}
{name === 'download' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M8 2v8M5 7l3 3 3-3"></path><path d="M3 13h10"></path></svg>
)}
{name === 'lock' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><rect x="3.5" y="7" width="9" height="6.5" rx="1.5"></rect><path d="M5.5 7V5a2.5 2.5 0 0 1 5 0v2"></path></svg>
)}
{name === 'scale' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M8 2v12M3 5h10M4.5 5 3 9h3zM11.5 5 10 9h3z"></path></svg>
)}
{name === 'spark' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M8 2v3M8 11v3M2 8h3M11 8h3M4.2 4.2l2 2M9.8 9.8l2 2M11.8 4.2l-2 2M6.2 9.8l-2 2"></path></svg>
)}
{name === 'star' && (
  <svg width={size} height={size} viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M9 2.5l1.9 3.9 4.3.6-3.1 3 .7 4.3L9 12.3l-3.8 2 .7-4.3-3.1-3 4.3-.6z"></path></svg>
)}
{name === 'star-avatar' && (
  <svg width={size} height={size} viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M9 2.4l1.9 3.95 4.35.6-3.15 3.05.74 4.3L9 12.27l-3.88 2.03.74-4.3L2.7 6.95l4.35-.6z"></path></svg>
)}
{name === 'qchat' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M3 3.5h10v7H7l-3 2.5V10.5H3z"></path></svg>
)}
